#!/bin/bash
# -*- coding: utf-8 -*-
# ============================================================
# 无代理环境下批量拉取实验室镜像（中国大陆可用，无需登录）
# 使用来源：DaoCloud (docker.m.daocloud.io) + 华为云 (swr...)
# 用法：sudo bash pull_all_images.sh
# ============================================================

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
info()    { echo -e "  ${GREEN}✓${NC} $*"; }
fail()    { echo -e "  ${RED}✗${NC} $*"; }
section() { echo -e "\n${CYAN}── $* ──${NC}"; }

FAILED_IMAGES=()

# ── 核心拉取函数（修复 pipe 吞退出码的 bug）─────────────────
pull_image() {
    local target="$1"; shift
    local sources=("$@")

    echo -e "\n▶ ${target}"

    # 已存在则跳过
    if docker image inspect "$target" > /dev/null 2>&1; then
        info "本地已存在，跳过"
        return 0
    fi

    for src in "${sources[@]}"; do
        echo -n "  尝试 ${src} ... "
        # 关键：不用管道，直接捕获退出码
        if docker pull "$src" > /tmp/dp_out.txt 2>&1; then
            echo -e "${GREEN}成功${NC}"
            if [ "$src" != "$target" ]; then
                docker tag "$src" "$target"
                docker rmi "$src" > /dev/null 2>&1 || true
            fi
            info "已就绪：$target"
            return 0
        else
            echo -e "${RED}失败${NC}"
            tail -1 /tmp/dp_out.txt | sed 's/^/    /'
        fi
    done

    fail "所有来源均失败：$target"
    FAILED_IMAGES+=("$target")
    return 1
}

# ── 国内可用镜像前缀（无需登录）─────────────────────────────
# DaoCloud：docker.m.daocloud.io/<org>/<image>:<tag>
# 华为云：  swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/<org>/<image>:<tag>
D="9wggzefxo5c8xeipi3.xuanyuan.run"
H="swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io"

# ══════════════════════════════════════════════════════════
section "数据库"

pull_image "mysql:8.0" \
    "${D}/mysql:8.0" \
    "${H}/mysql:8.0"

pull_image "redis:7.2-alpine" \
    "${D}/redis:7.2-alpine" \
    "${H}/redis:7.2-alpine"

pull_image "mongo:6.0" \
    "${D}/mongo:6.0" \
    "${H}/mongo:6.0"

pull_image "influxdb:2.7" \
    "${D}/influxdb:2.7" \
    "${H}/influxdb:2.7"

# ══════════════════════════════════════════════════════════
section "搜索 / 日志"

pull_image "elasticsearch:8.12.0" \
    "${D}/elasticsearch:8.12.0" \
    "${H}/elasticsearch:8.12.0"

pull_image "kibana:8.12.0" \
    "${D}/kibana:8.12.0" \
    "${H}/kibana:8.12.0"

# ══════════════════════════════════════════════════════════
section "对象存储 & 消息队列"

pull_image "minio/minio:latest" \
    "${D}/minio/minio:latest" \
    "${H}/minio/minio:latest"

pull_image "rabbitmq:3.12-management-alpine" \
    "${D}/rabbitmq:3.12-management-alpine" \
    "${H}/rabbitmq:3.12-management-alpine"

# ══════════════════════════════════════════════════════════
section "代码管理 & CI/CD（体积较大，请耐心等待）"

pull_image "gitlab/gitlab-ce:16.9.1-ce.0" \
    "${D}/gitlab/gitlab-ce:16.9.1-ce.0" \
    "${H}/gitlab/gitlab-ce:16.9.1-ce.0"

pull_image "jenkins/jenkins:lts-jdk17" \
    "${D}/jenkins/jenkins:lts-jdk17" \
    "${H}/jenkins/jenkins:lts-jdk17"

# ══════════════════════════════════════════════════════════
section "监控体系"

pull_image "prom/prometheus:latest" \
    "${D}/prom/prometheus:latest" \
    "${H}/prom/prometheus:latest"

pull_image "grafana/grafana:latest" \
    "${D}/grafana/grafana:latest" \
    "${H}/grafana/grafana:latest"

pull_image "prom/node-exporter:latest" \
    "${D}/prom/node-exporter:latest" \
    "${H}/prom/node-exporter:latest"

pull_image "zcube/cadvisor:latest" \
    "${D}/zcube/cadvisor:latest" \
    "${H}/zcube/cadvisor:latest"

# ══════════════════════════════════════════════════════════
section "测试报告"

pull_image "frankescobar/allure-docker-service:latest" \
    "${D}/frankescobar/allure-docker-service:latest" \
    "${H}/frankescobar/allure-docker-service:latest"

pull_image "frankescobar/allure-docker-service-ui:latest" \
    "${D}/frankescobar/allure-docker-service-ui:latest" \
    "${H}/frankescobar/allure-docker-service-ui:latest"

# ══════════════════════════════════════════════════════════
section "Nginx"

pull_image "nginx:alpine" \
    "${D}/nginx:alpine" \
    "${H}/nginx:alpine"

# ══════════════════════════════════════════════════════════
# 汇总
echo ""
echo -e "${CYAN}════════════════════════════════════════${NC}"
if [ ${#FAILED_IMAGES[@]} -eq 0 ]; then
    echo -e "${GREEN}✅ 所有镜像拉取完成！${NC}"
    echo ""
    echo "下一步，启动核心服务："
    echo "  cd /opt/lab-deploy && bash deploy.sh core"
else
    echo -e "${YELLOW}⚠️  以下镜像拉取失败（${#FAILED_IMAGES[@]} 个）：${NC}"
    for img in "${FAILED_IMAGES[@]}"; do
        echo "   - $img"
    done
    echo ""
    echo "可以重新运行此脚本，已成功的镜像会自动跳过："
    echo "  sudo bash pull_all_images.sh"
fi
echo -e "${CYAN}════════════════════════════════════════${NC}"

docker images --format "table {{.Repository}}:{{.Tag}}\t{{.Size}}" | grep -v REPOSITORY
