# ============================================================
# 座舱自动化测试实验室 - 全局环境变量
# 修改此文件后执行：docker compose up -d 生效
# ============================================================

# ── 基础路径 ──────────────────────────────────────────────
# WSL2 用户说明：
#   - /data 是 WSL2 内部路径，持久化数据会存在 WSL2 的虚拟磁盘里
#   - 若希望数据存在 Windows 磁盘，可改为 /mnt/d/lab-data（对应 D:\lab-data）
#   - 但建议保持 /data（性能更好，避免跨文件系统 IO 慢的问题）
DATA_ROOT=/data

# ── 域名 / IP ─────────────────────────────────────────────
LAB_DOMAIN=lab.internal

# WSL2 用户：SERVER_IP 填写 Windows 主机的局域网 IP（不是 WSL2 的 IP）
# 查看方法：在 Windows PowerShell 里执行 ipconfig，找 "以太网适配器" 或 "WLAN" 的 IPv4 地址
# 例如：192.168.1.88
SERVER_IP=10.69.62.20              # ← 改成你 Windows 主机的局域网 IP

# GitLab 对外地址同样用 Windows 主机 IP 或域名
GITLAB_EXTERNAL_URL=http://10.69.62.20:8929  # ← 改成你的 Windows IP

# ── MySQL ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=labadmin
MYSQL_DATABASE=testlab
MYSQL_USER=labadmin
MYSQL_PASSWORD=labadmin
MYSQL_PORT=3306

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=labadmin
REDIS_PORT=6379

# ── MongoDB ───────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=labadmin
MONGO_INITDB_ROOT_PASSWORD=labadmin
MONGO_PORT=27017

# ── InfluxDB ──────────────────────────────────────────────
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=labadmin
INFLUXDB_ORG=testlab
INFLUXDB_BUCKET=metrics
INFLUXDB_ADMIN_TOKEN=Lab-Influx-SuperToken-2025
INFLUXDB_PORT=8086

# ── Elasticsearch ─────────────────────────────────────────
ES_PASSWORD=labadmin
ES_PORT=9200
ES_JAVA_OPTS=-Xms1g -Xmx1g

# ── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=labadmin
MINIO_ROOT_PASSWORD=labadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=labadmin
RABBITMQ_DEFAULT_PASS=labadmin
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── GitLab ────────────────────────────────────────────────
GITLAB_ROOT_PASSWORD=labadmin
GITLAB_PORT_HTTP=8929
GITLAB_PORT_SSH=2224
GITLAB_EXTERNAL_URL=http://git.lab.internal

# ── Jenkins ───────────────────────────────────────────────
JENKINS_PORT=8080
JENKINS_AGENT_PORT=50000

# ── Grafana ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=labadmin
GRAFANA_PORT=3000

# ── Prometheus ────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Allure ────────────────────────────────────────────────
ALLURE_PORT=5050

# ── Nginx ─────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
